{
  "name": "webflow-image-processor",
  "version": "0.1.0",
  "type": "module",
  "description": "Scaffold for a Node.js + TypeScript service that fetches Webflow CMS items and minifies images with sharp.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "test": "tsx src/test.ts",
    "playground": "tsx src/playground.ts",
    "one-time-unpublish-related": "tsx src/scripts/oneTimeUnpublishRelated.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "analyze-log": "tsx src/scripts/analyzeLog.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "sharp": "^0.33.3",
    "webflow-api": "^3.1.3",
    "ssim.js": "^3.0.0",
    "uploadthing": "^7.7.3"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.5.0"
  }
} 